# ─── App ──────────────────────────────────────────────────────────────────────
# URL pública de la aplicación (cambiar por tu dominio de Hostinger)
APP_URL=https://tudominio.com

# ─── AI ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ─── Database ─────────────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
# Local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/snake_dragon
# EasyPanel (Docker interno — usar nombre del servicio como host):
# DATABASE_URL=postgresql://snake_user:PASSWORD@crm-db:5432/snake_dragon
# Supabase:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[SUPABASE_ID].supabase.co:5432/postgres

# Pool de conexiones (ajustar según RAM del VPS — 1 GB: max=10, 2 GB: max=20)
DB_POOL_MAX=20
DB_POOL_MIN=2
# Activar SSL solo si la DB está en un servicio externo separado (ej. Supabase)
DB_REQUIRE_SSL=false

# ─── Server ───────────────────────────────────────────────────────────────────
API_PORT=5000
NODE_ENV=production

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generá una clave segura con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_segura_de_64_caracteres_en_hex
JWT_EXPIRES_IN=8h

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_URL=https://tudominio.com/api
